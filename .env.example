# Copy this file to .env.local and paste your Gemini API key.
GEMINI_API_KEY=your_gemini_api_key_here

# Use separate models for each Gemini workflow.
GEMINI_DETECT_PDF_MODEL=gemini-2.5-flash
GEMINI_GENERATE_REPLIES_MODEL=gemini-2.5-flash

# Optional: set to true only when debugging. This logs prompts and full PDF base64 request bodies.
DEBUG_GEMINI_REQUESTS=false
